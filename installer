get_frequencies() {
  local decoder="$1"
  local region="${2:-north_america}"

  case "$decoder" in
    acarsdec)
      echo "${ACARS_FREQS[$region]:-${ACARS_FREQS[north_america]}}"
      ;;
    vdlm2dec|dumpvdl2)
      echo "${VDL2_FREQS[$region]:-${VDL2_FREQS[north_america]}}"
      ;;
    dumphfdl)
      # Default: 8 MHz band
      echo "${HFDL_FREQS[8]}"
      ;;
  esac
}

detect_region_from_timezone() {
  local tz
  tz=$(timedatectl show --property=Timezone --value 2>/dev/null || echo "")
  if [ -z "$tz" ]; then
    tz=$(cat /etc/timezone 2>/dev/null || echo "")
  fi
  if [ -z "$tz" ]; then
    tz="${TZ:-}"
  fi

  case "$tz" in
    America/*|US/*|Canada/*) echo "north_america" ;;
    Europe/*|Africa/*)       echo "europe" ;;
    Asia/*|Australia/*|Pacific/*) echo "asia_pacific" ;;
    *) echo "north_america" ;; # default
  esac
}

