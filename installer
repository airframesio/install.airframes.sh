pkg_install() {
  local -a pkgs=()
  for generic in "$@"; do
    local translated
    translated=$(pkg_translate "$generic")
    if [ -n "$translated" ]; then
      # Split space-separated packages (e.g., "gcc gcc-c++ make")
      read -ra parts <<< "$translated"
      pkgs+=("${parts[@]}")
    fi
  done

  if [ ${#pkgs[@]} -eq 0 ]; then
    return 0
  fi

  substep "Installing: ${pkgs[*]}"

  case "$PKG" in
    apt)
      sudo apt-get install -y -qq "${pkgs[@]}"
      ;;
    dnf)
      sudo dnf install -y -q "${pkgs[@]}"
      ;;
    pacman)
      sudo pacman -S --noconfirm --needed "${pkgs[@]}"
      ;;
    apk)
      sudo apk add --quiet "${pkgs[@]}"
      ;;
    brew)
      brew install "${pkgs[@]}" 2>/dev/null || true
      ;;
  esac
}

pkg_remove() {
  local pkg="$1"
  case "$PKG" in
    apt)    sudo apt-get remove -y -qq "$pkg" 2>/dev/null || true ;;
    dnf)    sudo dnf remove -y -q "$pkg" 2>/dev/null || true ;;
    pacman) sudo pacman -R --noconfirm "$pkg" 2>/dev/null || true ;;
    apk)    sudo apk del --quiet "$pkg" 2>/dev/null || true ;;
    brew)   brew uninstall "$pkg" 2>/dev/null || true ;;
  esac
}

pkg_update() {
  case "$PKG" in
    apt)    sudo apt-get update -qq ;;
    dnf)    : ;; # dnf auto-refreshes
    pacman) sudo pacman -Sy --noconfirm ;;
    apk)    sudo apk update --quiet ;;
    brew)   : ;; # brew auto-updates
  esac
}

# ===========================================================================
# Section 6: Platform detection
# ===========================================================================

detect_os() {
  case "$(uname -s)" in
    Linux)  OS="linux" ;;
    Darwin) OS="macos" ;;
    MINGW*|MSYS*|CYGWIN*)
      OS="windows"
      ;;
    *)
      err "Unsupported OS: $(uname -s)"
      exit 1
      ;;
  esac

  # WSL detection
  if [ "$OS" = "linux" ] && [ -f /proc/version ]; then
    if grep -qi "microsoft\|wsl" /proc/version 2>/dev/null; then
      IS_WSL=true
    fi
  fi
}

detect_arch() {
  case "$(uname -m)" in
    x86_64|amd64)   ARCH="amd64" ;;
    aarch64|arm64)   ARCH="arm64" ;;
    armv7l|armv6l)   ARCH="armv7" ;;
    i686|i386)       ARCH="386" ;;
    *)
      err "Unsupported architecture: $(uname -m)"
      exit 1
      ;;
  esac
}

detect_distro() {
  if [ "$OS" = "macos" ]; then
    DISTRO="macos"
    return
  fi

  if [ "$OS" = "windows" ]; then
    DISTRO="windows"
    return
  fi

  # Linux distro detection
  if [ -f /etc/os-release ]; then
    # shellcheck disable=SC1091
    . /etc/os-release
    case "$ID" in
      debian)    DISTRO="debian" ;;
      ubuntu)    DISTRO="ubuntu" ;;
      raspbian)  DISTRO="raspbian" ;;
      armbian)   DISTRO="armbian" ;;
      fedora)    DISTRO="fedora" ;;
      rocky)     DISTRO="rocky" ;;
      rhel|centos) DISTRO="rhel" ;;
      arch|manjaro) DISTRO="arch" ;;
      alpine)    DISTRO="alpine" ;;
      *)
        # Check for ID_LIKE as fallback
        case "${ID_LIKE:-}" in
          *debian*|*ubuntu*) DISTRO="debian" ;;
          *fedora*|*rhel*)   DISTRO="fedora" ;;
          *arch*)            DISTRO="arch" ;;
          *) DISTRO="unknown" ;;
        esac
        ;;
    esac
  elif [ -f /etc/debian_version ]; then
    DISTRO="debian"
  elif [ -f /etc/fedora-release ]; then
    DISTRO="fedora"
  elif [ -f /etc/arch-release ]; then
    DISTRO="arch"
  elif [ -f /etc/alpine-release ]; then
    DISTRO="alpine"
  else
    DISTRO="unknown"
  fi
}

detect_pkg_manager() {
  if [ "$OS" = "macos" ]; then
    if ! command -v brew >/dev/null 2>&1; then
      err "Homebrew is required on macOS. Install it from https://brew.sh"
      exit 1
    fi
    PKG="brew"
  elif command -v apt-get >/dev/null 2>&1; then
    PKG="apt"
  elif command -v dnf >/dev/null 2>&1; then
    PKG="dnf"
  elif command -v pacman >/dev/null 2>&1; then
    PKG="pacman"
  elif command -v apk >/dev/null 2>&1; then
    PKG="apk"
  else
    err "No supported package manager found (apt, dnf, pacman, apk, or brew)."
    exit 1
  fi
}

detect_platform() {
  detect_os
  detect_arch
  detect_distro
  detect_pkg_manager
}

# ===========================================================================
# Section 7: Gum install & UI abstraction
# ===========================================================================

install_gum() {
  if command -v gum >/dev/null 2>&1; then
    HAS_GUM=true
    return 0
  fi

  info "Installing gum for interactive UI..."

  case "$PKG" in
    apt)
      # Use Charm's apt repo
      sudo mkdir -p /etc/apt/keyrings
      curl -fsSL https://repo.charm.sh/apt/gpg.key | sudo gpg --dearmor -o /etc/apt/keyrings/charm.gpg 2>/dev/null
      echo "deb [signed-by=/etc/apt/keyrings/charm.gpg] https://repo.charm.sh/apt/ * *" | sudo tee /etc/apt/sources.list.d/charm.list >/dev/null
      sudo apt-get update -qq
      sudo apt-get install -y -qq gum
      ;;
    dnf)
      echo '[charm]
name=Charm
baseurl=https://repo.charm.sh/yum/
enabled=1
gpgcheck=1
gpgkey=https://repo.charm.sh/yum/gpg.key' | sudo tee /etc/yum.repos.d/charm.repo >/dev/null
      sudo dnf install -y -q gum
      ;;
    pacman)
      sudo pacman -S --noconfirm gum 2>/dev/null || {
        # Fallback to binary
        install_gum_binary
        return
      }
      ;;
    apk)
      sudo apk add --quiet gum 2>/dev/null || {
        install_gum_binary
        return
      }
      ;;
    brew)
      brew install gum
      ;;
  esac

  if command -v gum >/dev/null 2>&1; then
    HAS_GUM=true
    ok "gum installed"
  else
    install_gum_binary
  fi
}

install_gum_binary() {
  local gum_arch="$ARCH"
  local gum_os="$OS"
  [ "$gum_os" = "macos" ] && gum_os="Darwin"
  [ "$gum_os" = "linux" ] && gum_os="Linux"
  [ "$gum_arch" = "amd64" ] && gum_arch="x86_64"
  [ "$gum_arch" = "arm64" ] && gum_arch="aarch64"
  [ "$gum_arch" = "armv7" ] && gum_arch="armv7"

  local url="https://github.com/charmbracelet/gum/releases/download/v${GUM_VERSION}/gum_${GUM_VERSION}_${gum_os}_${gum_arch}.tar.gz"
  local tmp="/tmp/gum-install"

  mkdir -p "$tmp"
  if curl -fsSL "$url" | tar xz -C "$tmp" 2>/dev/null; then
    sudo install -m 755 "$tmp/gum" /usr/local/bin/gum 2>/dev/null || {
      install -m 755 "$tmp/gum" "$HOME/.local/bin/gum" 2>/dev/null
      export PATH="$HOME/.local/bin:$PATH"
    }
    rm -rf "$tmp"
    if command -v gum >/dev/null 2>&1; then
      HAS_GUM=true
      ok "gum installed"
    fi
  else
    warn "Could not install gum, falling back to plain menus"
  fi
}

# UI abstraction: gum when available, plain bash fallback

ui_choose() {
  local prompt="$1"
  shift
  local -a options=("$@")

  if [ "$HAS_GUM" = true ]; then
    gum choose --header "$prompt" "${options[@]}"
  else
    echo -e "\n  ${BOLD}${prompt}${RESET}" >&2
    local i=1
    for opt in "${options[@]}"; do
      echo -e "  ${CYAN}${i}${RESET})  ${opt}" >&2
      ((i++))
    done
    echo >&2
    local choice
    while true; do
      echo -ne "  ${BOLD}Select [1-${#options[@]}]: ${RESET}" >&2
      read -r choice
      if [[ "$choice" =~ ^[0-9]+$ ]] && [ "$choice" -ge 1 ] && [ "$choice" -le "${#options[@]}" ]; then
        echo "${options[$((choice-1))]}"
        return 0
      fi
      warn "Invalid selection" >&2
    done
  fi
}

ui_multichoice() {
  local prompt="$1"
  shift
  local -a options=("$@")

  if [ "$HAS_GUM" = true ]; then
    gum choose --no-limit --header "$prompt" "${options[@]}"
  else
    echo -e "\n  ${BOLD}${prompt}${RESET}" >&2
    echo -e "  ${DIM}(Enter numbers separated by spaces, e.g., 1 3 4)${RESET}" >&2
    local i=1
    for opt in "${options[@]}"; do
      echo -e "  ${CYAN}${i}${RESET})  ${opt}" >&2
      ((i++))
    done
    echo >&2
    local choices
    echo -ne "  ${BOLD}Select: ${RESET}" >&2
    read -r choices
    for idx in $choices; do
      if [[ "$idx" =~ ^[0-9]+$ ]] && [ "$idx" -ge 1 ] && [ "$idx" -le "${#options[@]}" ]; then
        echo "${options[$((idx-1))]}"
      fi
    done
  fi
}

ui_confirm() {
  local prompt="$1"
  local default="${2:-yes}"

  if [ "$AUTO_YES" = true ]; then
    return 0
  fi

  if [ "$HAS_GUM" = true ]; then
    if [ "$default" = "yes" ]; then
      gum confirm --default=yes "$prompt"
    else
      gum confirm --default=no "$prompt"
    fi
  else
    local yn
    if [ "$default" = "yes" ]; then
      echo -ne "  ${prompt} [Y/n] " >&2
      read -r yn
      [[ ! "$yn" =~ ^[Nn] ]]
    else
      echo -ne "  ${prompt} [y/N] " >&2
      read -r yn
      [[ "$yn" =~ ^[Yy] ]]
    fi
  fi
}

ui_input() {
  local prompt="$1"
  local default="${2:-}"

  if [ "$HAS_GUM" = true ]; then
    if [ -n "$default" ]; then
      gum input --placeholder "$prompt" --value "$default"
    else
      gum input --placeholder "$prompt"
    fi
  else
    local val
    if [ -n "$default" ]; then
      echo -ne "  ${prompt} [${default}]: " >&2
      read -r val
      echo "${val:-$default}"
    else
      echo -ne "  ${prompt}: " >&2
      read -r val
      echo "$val"
    fi
  fi
}

ui_spin() {
  local title="$1"
  shift

  if [ "$HAS_GUM" = true ]; then
    gum spin --spinner dot --title "$title" -- "$@"
  else
    info "$title"
    "$@"
  fi
}

