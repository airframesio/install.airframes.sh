  IS_TTY=true
else
  IS_TTY=false
fi

if [ "$IS_TTY" = true ]; then
  BOLD="\033[1m"
  DIM="\033[2m"
  ITALIC="\033[3m"
  CYAN="\033[36m"
  GREEN="\033[32m"
  YELLOW="\033[33m"
  RED="\033[31m"
  MAGENTA="\033[35m"
  BLUE="\033[34m"
  RESET="\033[0m"
else
  BOLD="" DIM="" ITALIC="" CYAN="" GREEN="" YELLOW="" RED="" MAGENTA="" BLUE="" RESET=""
fi

info()    { echo -e "${CYAN}[airframes]${RESET} $*"; }
ok()      { echo -e "${GREEN}[airframes]${RESET} $*"; }
warn()    { echo -e "${YELLOW}[airframes]${RESET} $*"; }
err()     { echo -e "${RED}[airframes]${RESET} $*" >&2; }
step()    { echo -e "\n${BOLD}==> $*${RESET}"; }
substep() { echo -e "  ${DIM}-> $*${RESET}"; }

