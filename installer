#!/usr/bin/env bash
#
# Airframes Installer
# https://install.airframes.sh/installer
#
# One-command setup for aviation decoders and Airframes feeding.
#
# Usage:
#   bash <(curl -sSL https://install.airframes.sh/installer)
#   bash <(curl -sSL https://install.airframes.sh/installer) acarsdec
#   bash <(curl -sSL https://install.airframes.sh/installer) --token <TOKEN>
#   bash <(curl -sSL https://install.airframes.sh/installer) -y all --region north_america
#
# Supports: Linux (Debian/Ubuntu/Raspbian/Fedora/Arch/Alpine), macOS (Homebrew)
#

set -euo pipefail

# ===========================================================================
# Section 1: Header / shebang / set options
# ===========================================================================

# Ensure we have bash 4+ (needed for associative arrays)
if [ "${BASH_VERSINFO[0]}" -lt 4 ]; then
  if [ "$(uname -s)" = "Darwin" ]; then
    # Try Homebrew bash
    if [ -x /opt/homebrew/bin/bash ]; then
      exec /opt/homebrew/bin/bash "$0" "$@"
    elif [ -x /usr/local/bin/bash ]; then
      exec /usr/local/bin/bash "$0" "$@"
    else
      echo "[airframes] bash 4+ required. Install with: brew install bash"
      exit 1
    fi
  else
    echo "[airframes] bash 4+ required (found ${BASH_VERSION})"
    exit 1
  fi
fi

# ===========================================================================
# Section 2: Constants & version
# ===========================================================================

