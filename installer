build_run_command() {
  local decoder="$1"
  local host="${FEED_HOST:-$AIRFRAMES_FEED_HOST}"
  local port="${FEED_PORT:-${DECODER_FEED_PORT[$decoder]}}"
  local freqs="${FREQUENCIES:-$(get_frequencies "$decoder" "${SELECTED_REGION:-north_america}")}"
  local sdr="${SELECTED_SDR:-rtlsdr}"

  case "$decoder" in
    acarsdec)
      echo "acarsdec -v -o 4 -g 42 -r 0 ${freqs} -j ${host}:${port}"
      ;;
    dumpvdl2)
      # dumpvdl2 takes frequencies in Hz
      local freqs_hz=""
      for f in $freqs; do
        if [[ "$f" == *.* ]]; then
          freqs_hz+=" $(echo "$f" | awk '{printf "%.0f", $1 * 1000000}')"
        else
          freqs_hz+=" $f"
        fi
      done
      case "$sdr" in
        rtlsdr)  echo "dumpvdl2 --rtlsdr 0${freqs_hz} --output decoded:json:udp:address=${host},port=${port}" ;;
        airspy)  echo "dumpvdl2 --airspy 0${freqs_hz} --output decoded:json:udp:address=${host},port=${port}" ;;
        sdrplay) echo "dumpvdl2 --soapysdr driver=sdrplay${freqs_hz} --output decoded:json:udp:address=${host},port=${port}" ;;
      esac
      ;;
    dumphfdl)
      local freq_args=""
      for f in $freqs; do
        freq_args+=" ${f}"
      done
      case "$sdr" in
        rtlsdr)  echo "dumphfdl --soapysdr driver=rtlsdr --sample-rate 250000 --output decoded:json:udp:address=${host},port=${port}${freq_args}" ;;
        airspy)  echo "dumphfdl --soapysdr driver=airspy --sample-rate 250000 --output decoded:json:udp:address=${host},port=${port}${freq_args}" ;;
        sdrplay) echo "dumphfdl --soapysdr driver=sdrplay --sample-rate 250000 --output decoded:json:udp:address=${host},port=${port}${freq_args}" ;;
      esac
      ;;
    vdlm2dec)
      echo "vdlm2dec -v -r 0 -G -E -U -j ${host}:${port} ${freqs}"
      ;;
  esac
}

show_run_command() {
  local decoder="$1"
  local cmd
  cmd=$(build_run_command "$decoder")

  echo
  ok "${decoder} is ready to feed Airframes!"
  echo
  info "Run this command to start feeding:"
  echo -e "  ${DIM}${cmd}${RESET}"
  echo
}

# ===========================================================================
# Section 17: Systemd service creation
# ===========================================================================

create_systemd_service() {
  local decoder="$1"
  local cmd
  cmd=$(build_run_command "$decoder")

  if [ "$OS" != "linux" ]; then
    warn "Systemd services are only supported on Linux"
    return 1
  fi

  if ! command -v systemctl >/dev/null 2>&1; then
    warn "systemctl not found — cannot create service"
    return 1
  fi

  local service_name="airframes-${decoder}"
  local service_file="/etc/systemd/system/${service_name}.service"

  step "Creating systemd service: ${service_name}"

  sudo tee "$service_file" >/dev/null << EOF
[Unit]
Description=Airframes ${decoder} decoder
After=network-online.target
Wants=network-online.target

[Service]
Type=simple
ExecStart=${cmd}
Restart=always
RestartSec=10
User=root
StandardOutput=journal
StandardError=journal

[Install]
WantedBy=multi-user.target
EOF

  sudo systemctl daemon-reload
  sudo systemctl enable "$service_name"
  sudo systemctl start "$service_name"

  ok "Service ${service_name} created and started"
  info "Check status: systemctl status ${service_name}"
  info "View logs: journalctl -u ${service_name} -f"
}

