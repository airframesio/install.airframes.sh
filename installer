usage() {
  cat << EOF
Airframes Installer v${VERSION}

Usage: installer [OPTIONS] [DECODER...]

Decoders:
  acarsdec    VHF ACARS decoder
  dumpvdl2    VDL Mode 2 decoder
  dumphfdl    HF Data Link decoder
  vdlm2dec    VDL Mode 2 decoder (alternative)
  all         Install all decoders

Options:
  -h, --help              Show this help message
  -v, --version           Show version
  -y, --yes               Skip confirmation prompts (automated mode)
  --token TOKEN           Use station token from web wizard
  --region REGION         Set region (north_america, europe, asia_pacific)
  --sdr TYPE              Set SDR type (rtlsdr, airspy, sdrplay)
  --method METHOD         Install method (source, docker, binary, package)
  --no-tui                Disable gum TUI, use plain menus
  --no-service            Don't offer to create systemd service
  --freq "F1 F2 ..."      Override frequencies

Examples:
  bash <(curl -sSL https://install.airframes.sh/installer)
  bash <(curl -sSL https://install.airframes.sh/installer) acarsdec
  bash <(curl -sSL https://install.airframes.sh/installer) --token abc123
  bash <(curl -sSL https://install.airframes.sh/installer) -y all --region north_america
  bash <(curl -sSL https://install.airframes.sh/installer) dumpvdl2 --sdr airspy --method docker
EOF
}

parse_args() {
  while [ $# -gt 0 ]; do
    case "$1" in
      -h|--help)
        usage
        exit 0
        ;;
      -v|--version)
        echo "Airframes Installer v${VERSION}"
        exit 0
        ;;
      -y|--yes)
        AUTO_YES=true
        shift
        ;;
      --token)
        TOKEN="$2"
        shift 2
        ;;
      --region)
        SELECTED_REGION="$2"
        shift 2
        ;;
      --sdr)
        SELECTED_SDR="$2"
        shift 2
        ;;
      --method)
        SELECTED_METHOD="$2"
        shift 2
        ;;
      --no-tui)
        USE_GUM=false
        shift
        ;;
      --no-service)
        CREATE_SERVICE=false
        SHOW_RUN_CMD=true
        shift
        ;;
      --freq)
        FREQUENCIES="$2"
        shift 2
        ;;
      acarsdec|dumpvdl2|dumphfdl|vdlm2dec)
        SELECTED_DECODERS+=("$1")
        shift
        ;;
      all)
        SELECTED_DECODERS=("${DECODER_LIST[@]}")
        shift
        ;;
      *)
        err "Unknown argument: $1"
        usage
        exit 1
        ;;
    esac
  done
}

