get_cmake_flags_for_sdr() {
  local decoder="$1"
  local sdr="${2:-rtlsdr}"
  local flags="${DECODER_CMAKE_FLAGS[$decoder]:-}"

  case "$decoder" in
    acarsdec|vdlm2dec)
      case "$sdr" in
        rtlsdr)  flags="-Drtl=ON" ;;
        airspy)  flags="-Dairspy=ON" ;;
        sdrplay) flags="-Dsdrplay=ON" ;;
      esac
      ;;
    dumpvdl2|dumphfdl)
      # These auto-detect SDR libraries at cmake time
      ;;
  esac

  echo "$flags"
}

# ===========================================================================
# Section 11: API integration
# ===========================================================================

api_fetch_config() {
  if [ -z "$TOKEN" ]; then
    return 1
  fi

  step "Fetching station configuration from Airframes..."

  local response
  response=$(curl -sf --max-time 15 \
    "${API_BASE}/installer/config?token=${TOKEN}" 2>/dev/null) || {
    err "Failed to fetch configuration. Check your token and try again."
    return 1
  }

  # Parse JSON without jq (grep/sed based)
  local _extract='s/.*"FIELD"\s*:\s*"\{0,1\}\([^",}]*\)"\{0,1\}.*/\1/p'

  local decoder source_type feed_host feed_port frequencies region ident

  decoder=$(echo "$response" | sed -n "${_extract/FIELD/decoder}")
  source_type=$(echo "$response" | sed -n "${_extract/FIELD/sourceType}")
  feed_host=$(echo "$response" | sed -n "${_extract/FIELD/feedHost}")
  feed_port=$(echo "$response" | sed -n "${_extract/FIELD/feedPort}")
  ident=$(echo "$response" | sed -n "${_extract/FIELD/ident}")
  region=$(echo "$response" | sed -n "${_extract/FIELD/region}")

  # Extract frequencies array
  frequencies=$(echo "$response" | grep -o '"frequencies"\s*:\s*\[[^]]*\]' | grep -o '"[0-9.]*"' | tr -d '"' | tr '\n' ' ')

  if [ -z "$decoder" ]; then
    err "Invalid configuration received from API"
    return 1
  fi

  SELECTED_DECODERS=("$decoder")
  FEED_HOST="${feed_host:-$AIRFRAMES_FEED_HOST}"
  FEED_PORT="${feed_port:-${DECODER_FEED_PORT[$decoder]:-5550}}"
  FREQUENCIES="${frequencies:-$(get_frequencies "$decoder" "${region:-north_america}")}"
  STATION_IDENT="${ident:-}"
  SELECTED_REGION="${region:-north_america}"

  ok "Station: ${STATION_IDENT}"
  ok "Decoder: ${decoder}"
  ok "Feed: ${FEED_HOST}:${FEED_PORT}"
  ok "Frequencies: ${FREQUENCIES}"

  api_report_status "installing_dependencies" "Starting installation" 5
  return 0
}

api_report_status() {
  if [ -z "$TOKEN" ]; then
    return 0
  fi

  local status="$1"
  local message="${2:-}"
  local percent="${3:-0}"

  # Fire-and-forget: don't block on failure
  curl -sf -X POST "${API_BASE}/installer/status" \
    -H "Content-Type: application/json" \
    -d "{\"token\":\"${TOKEN}\",\"status\":\"${status}\",\"message\":\"${message}\",\"percent\":${percent}}" \
    >/dev/null 2>&1 &
}

# ===========================================================================
# Section 12: Install method — compile from source
# ===========================================================================

nproc_count() {
  nproc 2>/dev/null || sysctl -n hw.ncpu 2>/dev/null || echo 2
}

install_base_deps() {
  step "Installing base build dependencies"
  pkg_update
  pkg_install build-essential cmake pkg-config git curl librtlsdr-dev libusb-dev
}

install_decoder_deps() {
  local decoder="$1"

  local extra="${DECODER_EXTRA_DEPS[$decoder]:-}"
  if [ -n "$extra" ]; then
    substep "Installing ${decoder} dependencies"
    # shellcheck disable=SC2086
    pkg_install $extra
  fi

  # Remove conflicting packages
  local remove="${DECODER_REMOVE_PKGS[$decoder]:-}"
  if [ -n "$remove" ]; then
    for pkg in $remove; do
      substep "Removing conflicting package: ${pkg}"
      pkg_remove "$pkg"
    done
  fi
}

build_libacars() {
  if [ -f "$BUILD_DIR/.libacars_built" ]; then
    info "libacars already built, skipping"
    return 0
  fi

  step "Building libacars"
  api_report_status "building_libacars" "Building libacars dependency" 20

  mkdir -p "$BUILD_DIR"
  cd "$BUILD_DIR"

  if [ ! -d libacars ]; then
    git clone --depth 1 "$LIBACARS_REPO"
  fi

  cd libacars
  mkdir -p build && cd build
  cmake ..
  make -j"$(nproc_count)"
  sudo make install

  if [ "$OS" = "linux" ]; then
    sudo ldconfig
  fi

  touch "$BUILD_DIR/.libacars_built"
  ok "libacars installed"
}

compile_decoder() {
  local decoder="$1"
  local repo="${DECODER_REPO[$decoder]}"
  local sdr="${SELECTED_SDR:-rtlsdr}"
  local cmake_flags
  cmake_flags=$(get_cmake_flags_for_sdr "$decoder" "$sdr")

  step "Building ${decoder}"
  api_report_status "building_decoder" "Building ${decoder} from source" 50

  mkdir -p "$BUILD_DIR"
  cd "$BUILD_DIR"

  if [ -d "$decoder" ]; then
    rm -rf "$decoder"
  fi

  git clone --depth 1 "$repo" "$decoder"
  cd "$decoder"
  mkdir -p build && cd build
  # shellcheck disable=SC2086
  cmake .. $cmake_flags
  make -j"$(nproc_count)"
  sudo make install

  if [ "$OS" = "linux" ]; then
    sudo ldconfig
  fi

  ok "${decoder} installed"
}

install_from_source() {
  local decoder="$1"

  install_decoder_deps "$decoder"
  build_libacars
  compile_decoder "$decoder"
}

# ===========================================================================
# Section 13: Install method — Docker containers
# ===========================================================================

ensure_docker() {
  if ! command -v docker >/dev/null 2>&1; then
    step "Installing Docker"
    if [ "$OS" = "linux" ]; then
      curl -fsSL https://get.docker.com | sudo sh
      sudo usermod -aG docker "$USER" 2>/dev/null || true
    elif [ "$OS" = "macos" ]; then
      err "Please install Docker Desktop from https://docker.com/products/docker-desktop"
      return 1
    fi
  fi

  if ! docker info >/dev/null 2>&1; then
    err "Docker is not running. Please start Docker and try again."
    return 1
  fi

  ok "Docker is ready"
}

install_with_docker() {
  local decoder="$1"
  local image="${DECODER_DOCKER_IMAGE[$decoder]:-}"

  if [ -z "$image" ]; then
    err "No Docker image available for ${decoder}"
    return 1
  fi

  ensure_docker || return 1

  step "Pulling Docker image for ${decoder}"
  api_report_status "building_decoder" "Pulling Docker image for ${decoder}" 50

  docker pull "$image"

  local port="${FEED_PORT:-${DECODER_FEED_PORT[$decoder]}}"
  local host="${FEED_HOST:-$AIRFRAMES_FEED_HOST}"
  local freqs="${FREQUENCIES:-$(get_frequencies "$decoder" "${SELECTED_REGION:-north_america}")}"

  # Generate docker-compose.yml
  local compose_dir="${CONFIG_DIR}/${decoder}"
  sudo mkdir -p "$compose_dir"

  local compose_file="${compose_dir}/docker-compose.yml"

  local env_block=""
  case "$decoder" in
    acarsdec)
      env_block="      FEED_ID: \"${STATION_IDENT:-airframes}\"
      FREQUENCIES: \"${freqs}\"
      OUTPUT_SERVER: \"${host}\"
      OUTPUT_SERVER_PORT: \"${port}\"
      OUTPUT_SERVER_MODE: \"json\""
      ;;
    dumpvdl2)
      local freqs_hz=""
      for f in $freqs; do
        if [[ "$f" == *.* ]]; then
          freqs_hz+=" $(echo "$f" | awk '{printf "%.0f", $1 * 1000000}')"
        else
          freqs_hz+=" $f"
        fi
      done
      env_block="      FEED_ID: \"${STATION_IDENT:-airframes}\"
      FREQUENCIES: \"${freqs_hz## }\"
      SERVER: \"${host}\"
      SERVER_PORT: \"${port}\""
      ;;
    dumphfdl)
      env_block="      FEED_ID: \"${STATION_IDENT:-airframes}\"
      FREQUENCIES: \"${freqs}\"
      SERVER: \"${host}\"
      SERVER_PORT: \"${port}\""
      ;;
    vdlm2dec)
      env_block="      FEED_ID: \"${STATION_IDENT:-airframes}\"
      FREQUENCIES: \"${freqs}\"
      SERVER: \"${host}\"
      SERVER_PORT: \"${port}\""
      ;;
  esac

  sudo tee "$compose_file" >/dev/null << EOF
version: '3.8'
services:
  ${decoder}:
    image: ${image}
    container_name: airframes-${decoder}
    restart: unless-stopped
    devices:
      - /dev/bus/usb:/dev/bus/usb
    environment:
${env_block}
EOF

  ok "Docker compose file created at ${compose_file}"
  info "Start with: cd ${compose_dir} && docker compose up -d"

  if ui_confirm "Start ${decoder} container now?"; then
    cd "$compose_dir"
    sudo docker compose up -d
    ok "${decoder} is running in Docker"
  fi
}

