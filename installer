declare -A SDR_VIDPID_MAP=(
  ["0bda:2838"]="rtlsdr"
  ["0bda:2832"]="rtlsdr"
  ["1d50:604b"]="airspy"
  ["1d50:60a1"]="airspy_hf"
  ["1df7:2500"]="sdrplay"
  ["1df7:3000"]="sdrplay"
  ["1df7:3010"]="sdrplay"
  ["1df7:3020"]="sdrplay"
  ["1df7:3030"]="sdrplay"
)

declare -A SDR_VIDPID_NAMES=(
  ["0bda:2838"]="RTL-SDR (RTL2838)"
  ["0bda:2832"]="RTL-SDR (RTL2832)"
  ["1d50:604b"]="Airspy Mini/R2"
  ["1d50:60a1"]="Airspy HF+"
  ["1df7:2500"]="SDRplay RSP1"
  ["1df7:3000"]="SDRplay RSP1A"
  ["1df7:3010"]="SDRplay RSP2"
  ["1df7:3020"]="SDRplay RSPduo"
  ["1df7:3030"]="SDRplay RSPdx"
)

detect_sdrs() {
  DETECTED_SDRS=()

  if [ "$OS" = "linux" ]; then
    if ! command -v lsusb >/dev/null 2>&1; then
      return
    fi

    local lsusb_output
    lsusb_output=$(lsusb 2>/dev/null) || return

    for vidpid in "${!SDR_VIDPID_MAP[@]}"; do
      if echo "$lsusb_output" | grep -qi "$vidpid"; then
        local sdr_type="${SDR_VIDPID_MAP[$vidpid]}"
        local sdr_name="${SDR_VIDPID_NAMES[$vidpid]}"
        DETECTED_SDRS+=("${sdr_type}:${sdr_name}")
      fi
    done

  elif [ "$OS" = "macos" ]; then
    local usb_output
    usb_output=$(system_profiler SPUSBDataType 2>/dev/null) || return

    # Check for known product names
    if echo "$usb_output" | grep -qi "RTL2838\|RTL2832\|RTL-SDR"; then
      DETECTED_SDRS+=("rtlsdr:RTL-SDR")
    fi
    if echo "$usb_output" | grep -qi "Airspy"; then
      DETECTED_SDRS+=("airspy:Airspy")
    fi
    if echo "$usb_output" | grep -qi "SDRplay"; then
      DETECTED_SDRS+=("sdrplay:SDRplay")
    fi
  fi
}

show_detected_sdrs() {
  if [ ${#DETECTED_SDRS[@]} -eq 0 ]; then
    warn "No SDR devices detected"
    info "Make sure your SDR is plugged in via USB"
    return 1
  fi

  ok "Detected SDR devices:"
  for sdr in "${DETECTED_SDRS[@]}"; do
    local sdr_name="${sdr#*:}"
    echo -e "  ${GREEN}●${RESET} ${sdr_name}"
  done
  return 0
}

get_sdr_type() {
  if [ ${#DETECTED_SDRS[@]} -gt 0 ]; then
    # Return the type of the first detected SDR
    local first="${DETECTED_SDRS[0]}"
    echo "${first%%:*}"
  else
    echo "rtlsdr"
  fi
}

