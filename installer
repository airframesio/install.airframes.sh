tui_select_decoders() {
  if [ "$HAS_GUM" = true ]; then
    step "Select decoders to install"

    local -a labels=()
    for d in "${DECODER_LIST[@]}"; do
      labels+=("${DECODER_LABEL[$d]}")
    done

    local selections
    selections=$(gum choose --no-limit --header "Select decoders to install:" "${labels[@]}") || {
      info "No decoders selected"
      exit 0
    }

    SELECTED_DECODERS=()
    while IFS= read -r line; do
      for d in "${DECODER_LIST[@]}"; do
        if [[ "$line" == "${DECODER_LABEL[$d]}" ]]; then
          SELECTED_DECODERS+=("$d")
        fi
      done
    done <<< "$selections"
  else
    step "Select decoders to install"
    echo -e "  ${DIM}(Enter numbers separated by spaces, e.g., 1 3)${RESET}"
    echo

    local i=1
    for d in "${DECODER_LIST[@]}"; do
      echo -e "  ${CYAN}${i}${RESET})  ${DECODER_LABEL[$d]}"
      ((i++))
    done
    echo -e "  ${CYAN}5${RESET})  All of the above"
    echo

    local choices
    echo -ne "  ${BOLD}Select: ${RESET}"
    read -r choices

    SELECTED_DECODERS=()
    for idx in $choices; do
      case "$idx" in
        5) SELECTED_DECODERS=("${DECODER_LIST[@]}"); break ;;
        [1-4]) SELECTED_DECODERS+=("${DECODER_LIST[$((idx-1))]}") ;;
      esac
    done
  fi

  if [ ${#SELECTED_DECODERS[@]} -eq 0 ]; then
    info "No decoders selected. Bye!"
    exit 0
  fi

  ok "Selected: ${SELECTED_DECODERS[*]}"
}

tui_select_method() {
  local methods=("Compile from source (recommended)" "Docker containers" "Pre-built binaries (coming soon)" "System packages (coming soon)")

  local choice
  choice=$(ui_choose "Installation method:" "${methods[@]}")

  case "$choice" in
    *source*)   SELECTED_METHOD="source" ;;
    *Docker*)   SELECTED_METHOD="docker" ;;
    *binaries*) SELECTED_METHOD="binary" ;;
