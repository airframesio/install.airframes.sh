  ok "SDR: ${SELECTED_SDR}"
}

tui_confirm_install() {
  echo
  step "Installation Summary"
  echo
  echo -e "  ${BOLD}Decoders:${RESET}  ${SELECTED_DECODERS[*]}"
  echo -e "  ${BOLD}Method:${RESET}    ${SELECTED_METHOD}"
  echo -e "  ${BOLD}Region:${RESET}    ${SELECTED_REGION}"
  echo -e "  ${BOLD}SDR:${RESET}       ${SELECTED_SDR}"
  if [ -n "$STATION_IDENT" ]; then
    echo -e "  ${BOLD}Station:${RESET}   ${STATION_IDENT}"
  fi
  echo

  if ! ui_confirm "Proceed with installation?"; then
    info "Aborted."
    exit 0
  fi
}

tui_post_install() {
  local decoder="$1"

  echo
  if [ "$OS" = "linux" ] && command -v systemctl >/dev/null 2>&1; then
    local actions=("Show run command" "Create systemd service (auto-start on boot)" "Both")
    local choice
    choice=$(ui_choose "How would you like to run ${decoder}?" "${actions[@]}")

    case "$choice" in
      *"Show run"*)
        show_run_command "$decoder"
        ;;
      *systemd*)
        create_systemd_service "$decoder"
        ;;
      *Both*)
        show_run_command "$decoder"
        create_systemd_service "$decoder"
        ;;
    esac
  else
    show_run_command "$decoder"
  fi
}

tui_flow() {
  show_banner

  # Detect platform
  info "Detected: ${OS} / ${ARCH} / ${DISTRO} / ${PKG}"
  if [ "$IS_WSL" = true ]; then
    info "Running under Windows Subsystem for Linux"
  fi
  echo

  # Install gum for TUI
  if [ "$USE_GUM" = true ]; then
    install_gum
  fi

  # Decoder selection
  tui_select_decoders

  # Installation method
  tui_select_method

  # Region selection
  tui_select_region

  # SDR selection
  tui_select_sdr

  # Confirmation
  tui_confirm_install

  # Install
  install_base_deps

  mkdir -p "$BUILD_DIR"

  for decoder in "${SELECTED_DECODERS[@]}"; do
    case "$SELECTED_METHOD" in
      source)  install_from_source "$decoder" ;;
      docker)  install_with_docker "$decoder" ;;
      binary)  install_from_binary "$decoder" ;;
      package) install_from_package "$decoder" ;;
    esac

    save_config "$decoder"
    tui_post_install "$decoder"
  done

  echo
  ok "Done! Thank you for feeding Airframes."
  info "Learn more at https://docs.airframes.io"
}

# ===========================================================================
# Section 21: Main entry point (mode dispatch)
# ===========================================================================

main() {
  parse_args "$@"
  detect_platform

  # Windows native (not WSL) — show guide and exit
  if [ "$OS" = "windows" ] && [ "$IS_WSL" = false ]; then
    show_banner
    echo
    warn "Native Windows is not directly supported."
    echo
    info "Options:"
    echo -e "  1. Install ${BOLD}WSL 2${RESET} (recommended): wsl --install"
    echo -e "  2. Use ${BOLD}Docker Desktop${RESET}: https://docker.com/products/docker-desktop"
    echo
    info "After installing WSL, run this installer again inside your WSL terminal."
    exit 0
  fi

  # Token mode: fetch config from API
  if [ -n "$TOKEN" ]; then
    show_banner
    info "Detected: ${OS} / ${ARCH} / ${DISTRO} / ${PKG}"
    echo

    api_fetch_config || exit 1

    if [ -z "$SELECTED_REGION" ]; then
      SELECTED_REGION=$(detect_region_from_timezone)
    fi

    install_base_deps
    mkdir -p "$BUILD_DIR"

    for decoder in "${SELECTED_DECODERS[@]}"; do
      case "$SELECTED_METHOD" in
        source)  install_from_source "$decoder" ;;
        docker)  install_with_docker "$decoder" ;;
        binary)  install_from_binary "$decoder" ;;
        package) install_from_package "$decoder" ;;
      esac

      save_config "$decoder"

      api_report_status "configuring" "Configuring ${decoder}" 80
      show_run_command "$decoder"

      if [ "$OS" = "linux" ] && command -v systemctl >/dev/null 2>&1; then
        if [ "$AUTO_YES" = true ] || ui_confirm "Create systemd service for ${decoder}?"; then
          create_systemd_service "$decoder"
          api_report_status "feeding" "${decoder} is feeding" 95
        fi
      fi
    done

    api_report_status "complete" "Installation complete" 100
    echo
    ok "Done! Thank you for feeding Airframes."
    info "Your station will appear on the dashboard shortly."
    exit 0
  fi

  # CLI mode: decoder(s) passed as arguments
  if [ ${#SELECTED_DECODERS[@]} -gt 0 ]; then
    show_banner
    info "Detected: ${OS} / ${ARCH} / ${DISTRO} / ${PKG}"
    echo

    if [ -z "$SELECTED_REGION" ]; then
      SELECTED_REGION=$(detect_region_from_timezone)
    fi

    if [ "$AUTO_YES" = false ]; then
      if ! ui_confirm "Install ${SELECTED_DECODERS[*]}?"; then
        info "Aborted."
        exit 0
      fi
    fi

    install_base_deps
    mkdir -p "$BUILD_DIR"

    for decoder in "${SELECTED_DECODERS[@]}"; do
      case "$SELECTED_METHOD" in
        source)  install_from_source "$decoder" ;;
        docker)  install_with_docker "$decoder" ;;
        binary)  install_from_binary "$decoder" ;;
        package) install_from_package "$decoder" ;;
      esac

      save_config "$decoder"
      show_run_command "$decoder"
    done

    echo
    ok "Done! Thank you for feeding Airframes."
    info "Learn more at https://docs.airframes.io"
    exit 0
  fi

  # TUI mode: no args, interactive
  if [ "$IS_TTY" = true ]; then
    tui_flow
  else
    # Piped without args and without a TTY — show help
    err "No decoder specified and no interactive terminal detected."
    echo
    usage
    exit 1
  fi
}

main "$@"
